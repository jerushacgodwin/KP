Options +FollowSymLinks
RewriteEngine On
RewriteBase /
# Proxy all non-file requests to Node.js app on the port provided by Hostinger
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ http://127.0.0.1:${PORT:-3000}/$1 [P,L]
# Allow direct access to static assets
RewriteCond %{REQUEST_URI} \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ [NC]
RewriteRule ^ - [L]
