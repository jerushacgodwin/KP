RewriteEngine On

# Proxy all requests to the Node.js app running on port 3000
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ http://localhost:3000/$1 [P,L]

# Allow direct file access for static assets if needed
ProxyPassMatch ^/(.*\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot))$ !
